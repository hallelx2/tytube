{
  "name": "tytube",
  "version": "0.1.0",
  "description": "A TypeScript port of pytube. Extract metadata and download YouTube videos without the YouTube Data API. Works in Node, Bun, and the browser.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    }
  },
  "bin": {
    "tytube": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write src",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "youtube",
    "downloader",
    "pytube",
    "video",
    "audio",
    "captions",
    "playlist",
    "channel",
    "search",
    "stream",
    "innertube",
    "bun",
    "typescript"
  ],
  "author": "hallelx2 <halleluyaholudele@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/hallelx2/tytube#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hallelx2/tytube.git"
  },
  "bugs": {
    "url": "https://github.com/hallelx2/tytube/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
